# GESTEMA - Variables de Entorno para Docker
# Copia este archivo a .env y configura los valores

# ===========================================
# CONFIGURACIÓN GENERAL
# ===========================================
ENVIRONMENT=development
DEBUG=true

# ===========================================
# GESTEMA TRADING
# ===========================================
SECRET_KEY=your-secret-key-change-in-production-32-chars-min
ENCRYPTION_KEY=your-encryption-key-32-chars-minimum

# Base de datos
DATABASE_URL=postgresql://gestema:gestema123@postgres:5432/gestema_trading

# Redis
REDIS_URL=redis://:redis123@redis:6379/0

# Brokers (opcional)
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

INTERACTIVE_BROKERS_GATEWAY_URL=localhost:7497
TD_AMERITRADE_API_KEY=your-td-api-key
CHARLES_SCHWAB_API_KEY=your-schwab-api-key
ROBINHOOD_USERNAME=your-robinhood-username
ROBINHOOD_PASSWORD=your-robinhood-password

# IA Models
HUGGINGFACE_API_TOKEN=your-huggingface-token
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ===========================================
# GESTEMA ADMIN
# ===========================================
ADMIN_SECRET_KEY=admin-secret-key-change-in-production-32-chars
ADMIN_ENCRYPTION_KEY=admin-encryption-key-32-chars-minimum

# Base de datos admin
ADMIN_DATABASE_URL=postgresql://gestema_admin:admin123@postgres:5432/gestema_admin

# Redis admin
ADMIN_REDIS_URL=redis://:redis123@redis:6379/1

# Configuración de staging
STAGING_DIRECTORY=./staging
STAGING_CLEANUP_HOURS=24
MAX_STAGING_INSTANCES=3

# IA Models para admin
ADMIN_MODEL_NAME=qwen2.5-7b-instruct
ADMIN_HUGGINGFACE_API_TOKEN=your-huggingface-token
ADMIN_OPENAI_API_KEY=your-openai-api-key

# Monitoreo
MONITOR_INTERVAL_SECONDS=30
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_DISK_THRESHOLD=90

# ===========================================
# SEGURIDAD
# ===========================================
# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MFA
MFA_ISSUER_NAME=GESTEMA
MFA_WINDOW=1

# Cifrado
ENCRYPTION_ALGORITHM=AES-256-GCM

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Trading logs
TRADING_LOG_FILE=./logs/gestema_trading.log
TRADING_AUDIT_LOG_FILE=./logs/trading_audit.log

# Admin logs
ADMIN_LOG_FILE=./logs/gestema_admin.log
ADMIN_AUDIT_LOG_FILE=./logs/admin_audit.log

# ===========================================
# NOTIFICACIONES
# ===========================================
# Email (opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@gestema.com

# Webhook (opcional)
WEBHOOK_URL=your-webhook-url
WEBHOOK_SECRET=your-webhook-secret

# ===========================================
# DESARROLLO
# ===========================================
# Hot reload
HOT_RELOAD=true
DEBUG_TOOLBAR=true

# Profiling
ENABLE_PROFILING=false

# Test mode
TEST_MODE=false

# ===========================================
# DOCKER
# ===========================================
# Compose project name
COMPOSE_PROJECT_NAME=gestema

# Network
DOCKER_NETWORK=gestema-network

# Volumes
POSTGRES_DATA_PATH=./data/postgres
REDIS_DATA_PATH=./data/redis
LOGS_PATH=./logs
BACKUP_PATH=./backup

# ===========================================
# SSL/TLS (para producción)
# ===========================================
# SSL Certificate paths (opcional)
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# Force HTTPS (para producción)
FORCE_HTTPS=false

# ===========================================
# BACKUP
# ===========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION=true
BACKUP_COMPRESSION=true

# ===========================================
# MONITOREO EXTERNO
# ===========================================
# Prometheus (opcional)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Grafana (opcional)
GRAFANA_ENABLED=false
GRAFANA_PORT=3000

# ===========================================
# CONFIGURACIÓN AVANZADA
# ===========================================
# Worker processes
WORKER_PROCESSES=4
WORKER_CONNECTIONS=1024

# Timeouts
PROXY_READ_TIMEOUT=60s
PROXY_CONNECT_TIMEOUT=60s
PROXY_SEND_TIMEOUT=60s

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Cache
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# ===========================================
# PLUGINS
# ===========================================
PLUGINS_ENABLED=true
PLUGINS_AUTO_LOAD=true
PLUGINS_DIRECTORY=./plugins
PLUGINS_MAX_SIZE_MB=50

# ===========================================
# GAMIFICACIÓN
# ===========================================
GAMIFICATION_ENABLED=true
XP_PER_TRADE=10
XP_PER_ACHIEVEMENT=50
MAX_LEVEL=100

# ===========================================
# REPORTES
# ===========================================
REPORTS_ENABLED=true
REPORTS_AUTO_GENERATE=true
REPORTS_SCHEDULE=0 0 * * 0  # Weekly on Sunday
REPORTS_RETENTION_DAYS=90
REPORTS_FORMATS=pdf,excel,csv